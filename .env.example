# Xavier credentials and secrets only.
# Non-secret runtime configuration lives in config/xavier.config.json.

# Core auth
XAVIER_TOKEN=replace-with-a-long-random-token

# Provider API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
GEMINI_API_KEY=

# Optional local/cloud provider auth
XAVIER_LOCAL_LLM_API_KEY=
XAVIER_LLM_API_KEY=

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CLOUD=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# SurrealDB credentials
XAVIER_SURREALDB_USER=
XAVIER_SURREALDB_PASS=

# Enterprise or internal add-ons
XAVIER_ENTERPRISE_API_KEY=
XAVIER_TOKEN_SECRET=
XAVIER_TELEGRAM_TOKEN=

# Optional runtime override for the canonical config file
XAVIER_CONFIG_PATH=
