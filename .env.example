# Xavier2 Environment Configuration

# --- Core Settings ---
# Image version tag
XAVIER2_IMAGE_TAG=0.4.1
# Auth token for API access (Required)
XAVIER2_TOKEN=replace-with-a-long-random-token
# Log level: error, warn, info, debug, trace
XAVIER2_LOG_LEVEL=info
RUST_LOG=info

# --- Network ---
XAVIER2_HOST=0.0.0.0
XAVIER2_PORT=8003

# --- Storage ---
# Base data directory
XAVIER2_DATA_DIR=/data
# Memory backend: vec (SQLite-vec) or surreal (SurrealDB)
XAVIER2_MEMORY_BACKEND=vec
# Path to code graph database
XAVIER2_CODE_GRAPH_DB_PATH=/data/code_graph.db
# Workspace directory
XAVIER2_WORKSPACE_DIR=/data/workspaces

# --- Retrieval Settings ---
# Reciprocal Rank Fusion parameter (default: 60)
XAVIER2_RRF_K=60
# Threshold for query-job-list quantization (default: 30000)
XAVIER2_QJL_THRESHOLD=30000
# Enable/Disable HyDE (Hypothetical Document Embeddings) - 1 to disable
XAVIER2_DISABLE_HYDE=1
# Enable/Disable entity extraction (1=on, 0=off)
XAVIER2_ENTITY_EXTRACTION_ENABLED=1
# Enable/Disable audit chain (1=on, 0=off)
XAVIER2_AUDIT_CHAIN_ENABLED=1

# --- Embedding Model ---
# URL for the embedding service
XAVIER2_EMBEDDING_URL=http://pplx-embed:8000
# Model name to use for embeddings
XAVIER2_EMBEDDING_MODEL=perplexity-ai/pplx-embed-v1-0.6b
# Dimensions for embeddings (must match the model)
XAVIER2_EMBEDDING_DIMENSIONS=768

# --- LLM Provider ---
# Model Provider (local, gemini, openai, minimax, anthropic)
XAVIER2_MODEL_PROVIDER=local
# Local LLM Configuration (for Ollama, LocalAI, vLLM)
XAVIER2_LOCAL_LLM_URL=http://localhost:11434/v1
XAVIER2_LOCAL_LLM_MODEL=llama3

# --- SurrealDB settings ---
# Only needed when XAVIER2_MEMORY_BACKEND=surreal
XAVIER2_SURREALDB_URL=ws://surrealdb:8000
XAVIER2_SURREALDB_NS=xavier2
XAVIER2_SURREALDB_DB=memory
XAVIER2_SURREALDB_USER=root
XAVIER2_SURREALDB_PASS=root
