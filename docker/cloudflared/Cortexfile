# Cloudflare Tunnel Configuration for Xavier Enterprise
# This config exposes Xavier via Cloudflare Tunnel

tunnel: xavier-enterprise
credentials-file: /etc/cloudflared/credentials.json

ingress:
  # Xavier HTTP API
  - hostname: xavier.swallowai.com
    service: http://xavier:8003
    originRequest:
      noTLSVerify: false
      connectTimeout: 30s

  # Health check
  - hostname: xavier-health.swallowai.com
    service: http://xavier:8003/health

  # Catch-all - don't route anything else
  - service: http_status:404
